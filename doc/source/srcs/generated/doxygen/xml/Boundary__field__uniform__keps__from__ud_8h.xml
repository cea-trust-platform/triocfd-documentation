<codeline lineno="38" refid="classBoundary__field__uniform__keps__from__ud_1a2817e2d9dc27596dcfd2df53dbb16767" refkind="member"><highlight class="normal"><sp/><sp/>Declare_instanciable(<ref refid="classBoundary__field__uniform__keps__from__ud" kindref="compound">Boundary_field_uniform_keps_from_ud</ref>);</highlight></codeline>
