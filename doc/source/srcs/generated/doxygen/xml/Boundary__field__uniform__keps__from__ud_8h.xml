<codeline lineno="43" refid="structpair_1a7510750330185514122d2b63734090c5" refkind="member"><highlight class="normal"><sp/><sp/></highlight><highlight class="keywordtype">double</highlight><highlight class="normal"><sp/><ref refid="structpair_1a7510750330185514122d2b63734090c5" kindref="member">k</ref>;</highlight></codeline>
